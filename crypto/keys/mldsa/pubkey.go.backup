package mldsa

import (
	"bytes"
	"errors"
	"fmt"
	"log"

	"github.com/cloudflare/circl/sign/mldsa/mldsa44"
	cmtcrypto "github.com/cometbft/cometbft/crypto"
	cryptotypes "github.com/cosmos/cosmos-sdk/crypto/types"
)

// Use the generated PrivKey and PubKey structs from protobuf
var (
	_ cryptotypes.PrivKey = (*PrivKey)(nil)
	_ cryptotypes.PubKey  = (*PubKey)(nil)
)

// GenPrivKey generates a new mldsa44 private key
func GenPrivKey() (*PrivKey, error) {
	_, privKey, err := mldsa44.GenerateKey(nil)
	if err != nil {
		return nil, err
	}

	keyBytes, err := privKey.MarshalBinary()
	if err != nil {
		return nil, fmt.Errorf("failed to marshal private key: %w", err)
	}

	return &PrivKey{Key: keyBytes}, nil
}

// NewPrivKeyFromSecret creates a mldsa44 private key from a 32-byte seed
func NewPrivKeyFromSecret(secret []byte) (*PrivKey, error) {
	if len(secret) != mldsa44.SeedSize {
		return nil, fmt.Errorf("secret must be %d bytes for mldsa44, got %d", mldsa44.SeedSize, len(secret))
	}

	var seed [mldsa44.SeedSize]byte
	copy(seed[:], secret)
	_, privKey := mldsa44.NewKeyFromSeed(&seed)

	keyBytes, err := privKey.MarshalBinary()
	if err != nil {
		return nil, fmt.Errorf("failed to marshal private key: %w", err)
	}

	return &PrivKey{Key: keyBytes}, nil
}

// PrivKey methods

func (pk *PrivKey) PubKey() cryptotypes.PubKey {
	if pk == nil || pk.Key == nil {
		return nil
	}

	privKey := new(mldsa44.PrivateKey)
	if err := privKey.UnmarshalBinary(pk.Key); err != nil {
		log.Printf("MLDSA44 PubKey() ERROR: failed to unmarshal private key: %v", err)
		return nil
	}

	pub := privKey.Public()
	if pub == nil {
		log.Printf("MLDSA44 PubKey() ERROR: Public() returned nil")
		return nil
	}

	pubKey, ok := pub.(*mldsa44.PublicKey)
	if !ok {
		log.Printf("MLDSA44 PubKey() ERROR: type assertion failed")
		return nil
	}

	pubKeyBytes, err := pubKey.MarshalBinary()
	if err != nil {
		log.Printf("MLDSA44 PubKey() ERROR: failed to marshal public key: %v", err)
		return nil
	}

	return &PubKey{Key: pubKeyBytes}
}

func (pk *PrivKey) Bytes() []byte {
	if pk == nil {
		return nil
	}
	return pk.Key
}

func (pk *PrivKey) Sign(msg []byte) ([]byte, error) {
	log.Printf("MLDSA44 Sign() called with message length: %d", len(msg))
	log.Printf("MLDSA44 Sign() message (first 100 bytes): %x", msg[:min(100, len(msg))])

	if pk == nil || pk.Key == nil {
		log.Printf("MLDSA44 Sign() ERROR: private key is nil")
		return nil, errors.New("private key is nil")
	}

	privKey := new(mldsa44.PrivateKey)
	if err := privKey.UnmarshalBinary(pk.Key); err != nil {
		log.Printf("MLDSA44 Sign() ERROR: failed to unmarshal private key: %v", err)
		return nil, fmt.Errorf("failed to unmarshal private key: %w", err)
	}

	signature := privKey.Scheme().Sign(privKey, msg, nil)
	log.Printf("MLDSA44 Sign() SUCCESS: signature length: %d", len(signature))
	log.Printf("MLDSA44 Sign() signature (first 50 bytes): %x", signature[:min(50, len(signature))])

	return signature, nil
}

func (pk *PrivKey) Type() string {
	return "tendermint/PrivKeyMLDSA44"
}

func (pk *PrivKey) Equals(other cryptotypes.LedgerPrivKey) bool {
	pk2, ok := other.(*PrivKey)
	if !ok {
		return false
	}
	if pk == nil && pk2 == nil {
		return true
	}
	if pk == nil || pk2 == nil {
		return false
	}
	return bytes.Equal(pk.Bytes(), pk2.Bytes())
}

// PubKey methods

func (pk *PubKey) Address() cmtcrypto.Address {
	if pk == nil || pk.Key == nil {
		log.Printf("MLDSA44 PubKey Address() ERROR: public key or Key field is nil")
		return nil
	}

	addr := cmtcrypto.AddressHash(pk.Key)
	log.Printf("MLDSA44 PubKey Address() generated address: %X from pubkey length: %d", addr, len(pk.Key))

	return addr
}

func (pk *PubKey) Bytes() []byte {
	if pk == nil {
		return nil
	}
	return pk.Key
}

func (pk *PubKey) VerifySignature(msg, sig []byte) bool {
	log.Printf("MLDSA44 VerifySignature() called")
	log.Printf("MLDSA44 VerifySignature() message length: %d", len(msg))
	log.Printf("MLDSA44 VerifySignature() message (first 100 bytes): %x", msg[:min(100, len(msg))])
	log.Printf("MLDSA44 VerifySignature() signature length: %d", len(sig))
	log.Printf("MLDSA44 VerifySignature() signature (first 50 bytes): %x", sig[:min(50, len(sig))])
	log.Printf("MLDSA44 VerifySignature() public key length: %d", len(pk.Key))

	if pk == nil || pk.Key == nil {
		log.Printf("MLDSA44 VerifySignature() ERROR: public key or Key field is nil")
		return false
	}

	var pubKey mldsa44.PublicKey
	if err := pubKey.UnmarshalBinary(pk.Key); err != nil {
		log.Printf("MLDSA44 VerifySignature() ERROR: failed to unmarshal public key: %v", err)
		return false
	}

	result := mldsa44.Verify(&pubKey, msg, sig, nil)
	log.Printf("MLDSA44 VerifySignature() result: %v", result)

	// Let's also test with the original key pair to make sure our implementation works
	if !result {
		log.Printf("MLDSA44 VerifySignature() DEBUGGING: signature verification failed")
		log.Printf("MLDSA44 VerifySignature() DEBUGGING: pubkey bytes: %x", pk.Key[:min(50, len(pk.Key))])
	}

	return result
}

func (pk *PubKey) Type() string {
	return "tendermint/PubKeyMLDSA44"
}

func (pk *PubKey) Equals(other cryptotypes.PubKey) bool {
	pk2, ok := other.(*PubKey)
	if !ok {
		return false
	}
	return bytes.Equal(pk.Key, pk2.Key)
}

func (pk *PubKey) String() string {
	return fmt.Sprintf("PubKeyMLDSA44{%X}", pk.Key[:min(20, len(pk.Key))])
}

func min(a, b int) int {
	if a < b {
		return a
	}
	return b
}
